# ========================
# Compiled Output & Build
# ========================
target/
build/
out/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# Keep Maven wrapper jar excluded but allow the .mvn directory
.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties
!.mvn/jvm.config

# Preserve source directories even if they happen to be named target/build
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# ========================
# Logs
# ========================
*.log
logs/
log/

